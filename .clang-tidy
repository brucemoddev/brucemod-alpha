Checks: '-*,bugprone-*,modernize-*,performance-*,readability-*,-modernize-use-trailing-return-type,-modernize-use-nodiscard,-modernize-use-override'
WarningsAsErrors: ''
HeaderFilterRegex: 'src/.*'
AnalyzeTemporaryDtors: false
CheckOptions:
  - key:             readability-identifier-naming.ClassCase
    value:           CamelCase
  - key:             readability-identifier-naming.FunctionCase
    value:           camelBack
  - key:             readability-identifier-naming.VariableCase
    value:           camelBack
